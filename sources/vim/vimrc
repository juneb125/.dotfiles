set nocompatible

" -- Options -- {{{
" ui
set number cursorline showmatch termguicolors
set signcolumn=yes
set laststatus=2
set helpheight=15

" tabs & identation
set tabstop=2 shiftwidth=2

" search settings
set ignorecase smartcase hlsearch incsearch

" misc.
set mouse=nv
set nowrap noswapfile
set foldmethod=marker

set splitright splitbelow

set clipboard+=unnamedplus

set completeopt=menu,popup,noinsert
set wildignorecase
set formatoptions=jtcl

set fillchars+=vert:│

" }}}
set shortmess-=I

" -- Keymaps -- {{{
nnoremap "\<Space>" <Nop>
let g:mapleader = " "
let g:localmapleader = "\\"

nnoremap <silent> <leader>wt :set wrap!<CR>
nnoremap <silent> <leader>sc :setlocal spell!<CR>

tnoremap <Esc> <C-\><C-n>

" *sometimes* emacs is right {{{
inoremap <C-a> <C-o>I
inoremap <C-e> <C-o>A
inoremap <C-b> <C-o>h
inoremap <C-f> <C-o>l

cnoremap <C-a> <C-b>
" <C-e> is already end-of-line in cmd mode
cnoremap <C-b> <Left>
cnoremap <C-f> <Right>
" }}}

nnoremap <C-k> <C-w>k
nnoremap <C-j> <C-w>j
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l

nnoremap <silent> <leader>nh :nohlsearch<CR>

vnoremap < <gv
vnoremap > >gv

nnoremap <silent> [t :tabprev<CR>
nnoremap <silent> ]t :tabnext<CR>
" }}}

" disable some builtin plugins
let g:loaded_gzip = 1
let g:loaded_tarPlugin = 1
let g:loaded_tutor_mode_plugin = 1
let g:loaded_zipPlugin = 1
let g:loaded_2html_plugin = 1

" ./colors/catppuccin_mocha.vim from
"   https://github.com/catppuccin/vim/blob/main/colors/catppuccin_mocha.vim
colorscheme catppuccin_mocha

set statusline=%{%GetStlLeft()%}%=%{GetStlRight()}

" File Explorer {{{
let g:netrw_dirhistmax = 0

" command! -nargs=? -complete=file Fexplore call FloatExplore(<f-args>)
" command! -nargs=? -complete=file Fex call FloatExplore(<f-args>)
nnoremap <silent> - :Fexplore<CR>
" }}}

filetype plugin indent on
syntax on
